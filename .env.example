# ESV API — https://api.esv.org/ 에서 무료 발급
ESV_API_KEY=

# Google Cloud TTS — 서비스 계정 JSON 파일 절대경로
GOOGLE_APPLICATION_CREDENTIALS=

# 선택: Google TTS 음성 (생략 시 아래 기본값 사용)
# 한국어 여자 음성 후보:
#   ko-KR-Neural2-A (기본, 차분한 톤)
#   ko-KR-Neural2-B (조금 더 밝은 톤)
# 한국어 남자 음성: ko-KR-Neural2-C, ko-KR-Wavenet-C, ko-KR-Wavenet-D
# 샘플 듣는 곳:  https://cloud.google.com/text-to-speech/docs/list-voices-and-types
GOOGLE_KO_VOICE=
# 영어 음성 (ElevenLabs 폴백 시 사용). 예: en-US-Neural2-F (여자), en-US-Neural2-J (남자)
GOOGLE_EN_VOICE=

# ElevenLabs — https://elevenlabs.io/
ELEVEN_API_KEY=
# 선택: 사용할 음성 ID (생략 시 Rachel)
ELEVEN_VOICE_ID=

# 선택: 영어 TTS 엔진 고정 (eleven | google).
# 설정하면 한도와 무관하게 매번 그 엔진만 사용. CLI의 --force-engine이 우선.
# Google로 통일하고 싶으면 google 으로 설정.
FORCE_ENGINE=google
